    ,core.fn_aut001_nm_line_format(nm_linha_new) nm_mascara_linha_new --adicionado em 4/7
    ,`dev-autopass-bi-001.core.fn_aut001_nm_station_format`( nm_estacao_new) nm_mascara_estacao_new  
    from union_catracadas
    )
  select
  produto_agrupado
    , valorado
    , repasse_clearing
    , comissionamento
    ,origem
    ,ts_processing as dh_atualizacao
    ,cd_origem_sistema
    ,ds_tipo_dispositivo
    ,cd_empresa
    ,dt_uso
    ,dt_clearing
    ,ds_tipo_cartao
    ,REPLACE(ds_consorcio, 'CONSORCIO', '') AS ds_consorcio
    --,ds_consorcio
    ,ds_abrangencia
    ,ds_modal
    ,ds_produto
    ,nm_empresa
    ,nm_empresa_new
    ,nm_linha
    ,nm_linha_new
    ,nm_estacao
    ,nm_estacao_new
    ,cd_status_embarque
    ,nm_estacao_linha
    ,nm_estacao_linha_new
    ,sum(qt_uso) as qt_uso
    ,sum(valor_uso) as valor_uso
    ,ds_mascara_produto
    ,nm_mascara_linha
    ,nm_mascara_linha_new
    ,nm_mascara_estacao
    ,nm_mascara_estacao_new
    ,case
    WHEN  ds_mascara_produto = 'ESPECIAL'	THEN 'NAO VALORADA'
    WHEN  ds_mascara_produto = 'FUNCIONAL' THEN	'NAO VALORADA'
    WHEN  ds_mascara_produto = 'ESCOLAR' THEN	'VALORADA'
    WHEN  ds_mascara_produto = 'PAGANTE DINHEIRO' THEN	'PAGANTE DINHEIRO'
    WHEN  ds_mascara_produto = 'GRATUIDADE' THEN	'NAO VALORADA'
    WHEN  ds_mascara_produto = 'SENIOR' THEN	'NAO VALORADA'
    WHEN  ds_mascara_produto = 'VALE TRANSPORTE' THEN	'VALORADA'
    WHEN  ds_mascara_produto = 'COMUM' THEN	'VALORADA'
    WHEN  ds_mascara_produto = 'QR CODE' THEN 'VALORADA' --PRECISAMOS CERTIFICAR?
    WHEN  ds_mascara_produto = 'BU' THEN 'VALORADA' --PRECISAMOS CERTIFICAR?
    WHEN ds_mascara_produto = 'EMV' THEN 'VALORADA'
    WHEN  ds_mascara_produto = 'SENIOR PAULISTA' THEN	'NAO VALORADA'
    WHEN  ds_mascara_produto = 'TESTE' THEN	'NAO VALORADA'
    WHEN  ds_mascara_produto = 'QRCODE' THEN 'VALORADA' --PRECISAMOS CERTIFICAR?
    WHEN  ds_mascara_produto = 'ABT' THEN 'VALORADA' --PRECISAMOS CERTIFICAR?
    WHEN  ds_mascara_produto = 'BENFACIL' THEN 'VALORADA'
    WHEN  ds_mascara_produto = 'EMPRESARIAL' THEN 'VALORADA'
    WHEN  ds_mascara_produto = 'QR METRA TRANSF' THEN 'QR METRA TRANSF'
    WHEN  ds_mascara_produto = 'TOP TROCA' THEN 'TOP TROCA'
    WHEN  ds_mascara_produto = 'DESEMPREGADO' THEN 'NAO VALORADA'
    WHEN  ds_mascara_produto = 'RAPOSO MUNI' THEN 'NAO VALORADA'
    else 'N/A'
    end ds_mascara_aplicacao,
    SHA256(CONCAT(COALESCE(nm_mascara_estacao, ''), COALESCE(nm_mascara_linha, ''))) AS cd_estacao_linha ,
    SHA256(CONCAT(COALESCE(nm_mascara_estacao_new , ''), COALESCE(nm_mascara_linha_new , ''))) AS cd_estacao_linha_new --adicionado em 13/12
  from finalizacao_union
  group by all  