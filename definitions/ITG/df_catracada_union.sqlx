config {
    type: "table", 
    schema: "itg",
    description: "Tabela itg de vendas por cartão ",
    tags: ["itg"],
    bigquery: {
        partitionBy: "dt_uso",
    }
}


WITH union_catracadas as (
    SELECT
    'BOM' as origem
    ,ts_processing
    ,cd_system_source as cd_origem_sistema
    ,'N/A' as ds_tipo_dispositivo
    ,cd_company as cd_empresa
    ,dt_card_usage as dt_uso
    ,dt_process_start as dt_clearing
    ,'PURO TRANSPORTE' ds_tipo_cartao
    ,ds_consortium as ds_consorcio
    ,ds_consortium_group as ds_abrangencia
    ,ds_modal as ds_modal
    ,ds_product as ds_produto
    ,'' as produto_agrupado
    ,'' as valorado
    ,'' as repasse_clearing
    ,'' as comissionamento
    ,nm_company as nm_empresa
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao
    ,nm_company as nm_empresa_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao_new 
    ,cd_boarding_status as cd_status_embarque
    ,COUNT(dt_card_usage) qt_uso
    ,SUM(vl_fare) valor_uso
    FROM prd-autopass-bi-001.itg.vw_itg_trs_bom001_card_usage_gate tese
    WHERE dt_card_usage >= date_sub(DATE_TRUNC(CURRENT_DATE(), MONTH), interval 2 year)
    GROUP BY ALL
    union all
    SELECT
    'EMV' as origem
    ,ts_processing
    , cd_system_source as cd_origem_sistema
    ,'N/A' as ds_tipo_dispositivo
    ,cd_company as cd_empresa
    ,dt_card_usage as dt_uso
    ,dt_process_start as dt_clearing
    ,'N/A' ds_tipo_cartao
    ,ds_consortium as ds_consorcio
    ,ds_consortium_group as ds_abrangencia
    ,ds_modal as ds_modal
    ,ds_product as ds_produto
    ,'' as produto_agrupado
    ,'' as valorado
    ,'' as repasse_clearing
    ,'' as comissionamento
    ,nm_company as nm_empresa
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao
    ,nm_company as nm_empresa_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao_new
    ,cd_boarding_status as cd_status_embarque
    --,CONCAT(nm_line,nm_station) nm_estacao_linha
    ,COUNT(dt_card_usage) qt_uso
    ,SUM(vl_fare) valor_uso
    FROM prd-autopass-bi-001.itg.vw_itg_trs_top001_emv_card_usage_gate tese
    WHERE dt_card_usage >= date_sub(DATE_TRUNC(CURRENT_DATE(), MONTH), interval 2 year)
    GROUP BY ALL

    union all

    SELECT
    'TOP' as origem
    ,ts_processing
    , cd_system_source as cd_origem_sistema
    ,'N/A' as ds_tipo_dispositivo
    ,cd_company as cd_empresa
    ,dt_card_usage as dt_uso
    ,dt_process_start_clearing as dt_clearing
    ,ds_card ds_tipo_cartao
    ,ds_consortium as ds_consorcio
    ,ds_consortium_group as ds_abrangencia
    ,ds_modal as ds_modal
    ,ds_product as ds_produto
    ,produto_agrupado
    ,valorado
    ,repasse_clearing
    ,comissionamento
    ,nm_company as nm_empresa
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao
    ,nm_company as nm_empresa_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_line
    END as nm_linha_new
    ,CASE 
      WHEN ds_modal = 'PNEU' THEN 'N/A' 
      ELSE nm_station
    END as nm_estacao_new
    ,cd_boarding_status as cd_status_embarque
    --,CONCAT(nm_line,nm_station) nm_estacao_linha
    ,COUNT(dt_card_usage) qt_uso
    ,SUM(vl_fare) valor_uso
    FROM  -- `dev-autopass-bi-001.tmp.top001_card_usage_gate_NEW` tese
           --  `prd-autopass-bi-001.itg.tb_itg_trs_top001_card_usage_gate`  tese
             dev-autopass-bi-001.itg.tb_itg_trs_top001_card_usage_gate  tese
    WHERE dt_card_usage >= date_sub(DATE_TRUNC(CURRENT_DATE(), MONTH), interval 2 year)
    GROUP BY ALL
    union all
    select
    'QRCODE' as origem
    ,ts_processing
    ,cd_system_source as cd_origem_sistema
    ,ds_device_type as ds_tipo_dispositivo
    ,cd_company as cd_empresa
    ,dt_usage as dt_uso
    ,dt_process_start as dt_clearing
    ,'N/A' ds_tipo_cartao
    ,nm_company as ds_consorcio
    ,'N/A' as ds_abrangencia
    ,'TRILHO' as ds_modal
    ,ds_product as ds_produto
    ,'' as produto_agrupado
    ,'' as valorado
    ,'' as repasse_clearing
    ,'' as comissionamento
    ,TRIM(IFNULL(SPLIT(nm_company, '-')[SAFE_OFFSET(1)], nm_company)) nm_empresa
    ,TRIM(IFNULL(SPLIT(nm_line, '-')[SAFE_OFFSET(1)], nm_line)) nm_linha
    ,TRIM(IFNULL(SPLIT(nm_station, '-')[SAFE_OFFSET(1)], nm_station)) nm_estacao

    ,TRIM(IFNULL(SPLIT(nm_company_usage, '-')[SAFE_OFFSET(1)], nm_company_usage)) nm_empresa_new
    ,TRIM(IFNULL(SPLIT(nm_line_usage, '-')[SAFE_OFFSET(1)], nm_line_usage)) nm_linha_new
    ,TRIM(nm_station_usage) nm_estacao_new
    ,'N/A' as cd_status_embarque
    --,CONCAT(TRIM(IFNULL(SPLIT(nm_line, '-')[SAFE_OFFSET(1)], nm_line)),TRIM(IFNULL(SPLIT(nm_station, '-')[SAFE_OFFSET(1)], nm_station))) nm_estacao_linha
    ,count(cd_qrcode_media) as qt_uso
    ,sum(vl_unit_price) as valor_uso
    from `prd-autopass-bi-001.itg.vw_itg_trs_top001_qrcode_usage`
    where dt_usage >= date_sub(DATE_TRUNC(CURRENT_DATE(), MONTH), interval 2 year)
    group by all
    ),


    finalizacao_union as (
    select
    produto_agrupado
    , valorado
    , repasse_clearing
    , comissionamento
    ,origem
    ,ts_processing
    ,ds_tipo_dispositivo
    ,cd_origem_sistema
    ,cd_empresa
    ,dt_uso
    ,dt_clearing
    ,ds_tipo_cartao
    ,ds_consorcio
    ,ds_abrangencia
    ,ds_modal
    ,ds_produto
    ,nm_empresa
    ,nm_linha
    ,nm_estacao
    ,nm_empresa_new
    ,nm_linha_new
    ,nm_estacao_new
    ,cd_status_embarque
    ,CONCAT(nm_linha,nm_estacao) nm_estacao_linha
    ,CONCAT(nm_linha_new,nm_estacao_new) nm_estacao_linha_new
    ,qt_uso
    ,valor_uso
    ,CASE
    WHEN ds_produto = 'AC ARUJA' THEN 'ESPECIAL'
    WHEN ds_produto = 'AC COTIA' THEN 'ESPECIAL'
    WHEN ds_produto = 'AC TABOAO' THEN 'ESPECIAL'
    WHEN ds_produto = 'ACOMP.' THEN 'ESPECIAL'
    WHEN ds_produto = 'BOTOEIRAS' THEN 'PAGANTE DINHEIRO'
    WHEN ds_produto = 'COMUM' THEN 'COMUM'
    WHEN ds_produto = 'ESC ARUJA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC COTIA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC MT PREF' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC MT SEC EDU' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC PAULISTA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC PL COTIA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC PL RGS' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESC. TABOAO' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESP ARUJA' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP ARUJA AC' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP COTIA' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP COTIA AC' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP TABOAO' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP TABOAO AC' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESP. C/AC' THEN 'ESPECIAL'
    WHEN ds_produto = 'ESPECIAL' THEN 'ESPECIAL'
    WHEN ds_produto = 'FUNCIONAL' THEN 'FUNCIONAL'
    WHEN ds_produto = 'GRATUIDADE' THEN 'GRATUIDADE'
    WHEN ds_produto = 'MAE COTIANA' THEN 'GRATUIDADE'
    WHEN ds_produto = 'PGTE MOEDEIRA' THEN 'PAGANTE DINHEIRO'
    WHEN ds_produto = 'SENIOR' THEN 'SENIOR'
    WHEN ds_produto = 'SENIOR ARUJA' THEN 'SENIOR'
    WHEN ds_produto = 'SENIOR COTIA' THEN 'SENIOR'
    WHEN ds_produto = 'SENIOR PAULISTA' THEN 'SENIOR PAULISTA'
    WHEN ds_produto = 'SENIOR RGS' THEN 'SENIOR'
    WHEN ds_produto = 'V.T.' THEN 'VALE TRANSPORTE'
    WHEN ds_produto = 'VT' THEN 'VALE TRANSPORTE'
    WHEN ds_produto = 'V.T. GUARUPAS' THEN 'FUNCIONAL'
    WHEN ds_produto = 'AGENTES TABOAO' THEN 'FUNCIONAL'
    WHEN ds_produto = 'COLABORADOR' THEN 'FUNCIONAL'
    WHEN ds_produto IN ('TESTE MOBI 8/9','TOP TESTE CPTM', 'TOP TESTE METRO', 'TOP TESTE VIA4', 'TESTE BNT', 'TESTE VIA MOBI') THEN 'TESTE'
    WHEN ds_produto = 'SENIOR TABOAO' THEN 'SENIOR PAULISTA'
    WHEN ds_produto = 'COMUM' THEN 'COMUM'
    WHEN ds_produto = 'COMUM TOP' THEN 'COMUM'
    WHEN ds_produto = 'COMUM VALONLINE' THEN 'COMUM'
    WHEN ds_produto = 'ESC TABOAO ABASP' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR ARUJA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR COTIA' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR TABOAO' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR TABOAO MUNI' THEN 'ESCOLAR'
    WHEN ds_produto = 'ESCOLAR TOP' THEN 'ESCOLAR'
    WHEN ds_produto = 'TOP COMUM' THEN 'COMUM'
    WHEN ds_produto = 'TOP ESCOLAR' THEN 'ESCOLAR'
    WHEN ds_produto = 'VT TOP' THEN 'VALE TRANSPORTE'
    WHEN ds_produto = 'ESCOLAR DINH.' THEN 'ESCOLAR'	--tmob
    WHEN ds_produto = 'VC D INTEG.' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'VC D TRILHO' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'VE D G TRI' THEN 'ESCOLAR'	--tmob
    WHEN ds_produto = 'RESTITUICAO' THEN 'RESTITUICAO'	--tmob
    WHEN ds_produto = 'VC M ONIBUS' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'FIDELIDADE 20' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'VALE TRANSPORTE TOP' THEN 'VALE TRANSPORTE'	--tmob
    WHEN ds_produto = 'VC D ONIBUS' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'VC M TRILHO' THEN 'COMUM'	--tmob
    WHEN ds_produto = 'FIDELIDADE 50' THEN 'COMUM'	--tmob
    WHEN ds_produto in ('QR PLBS', 'QR SUPRESSAO', 'QR SUPRESSAO CPTM', 'QR TESTE METRO', 'QRCODE NEXT INTEG', 'LOTE UNITARIO', 'PRODUTO QRCODE', 'UNITARIO', 'UNITARIO OFFLINE', 'PRODUTO QRCODE A', 'QRCONTING')   THEN 'QR CODE'
    WHEN ds_produto in ('ESP.', 'ESP. TABOAO AC', 'ACOMP TABOAO', 'ESPECIAL TABOAO') THEN 'ESPECIAL'
    WHEN ds_produto in ('AGENTES', 'COLAB CPTM', 'FUNC GUARUPAS') THEN 'FUNCIONAL'
    WHEN ds_produto in ('PGTE', 'PGTE GUARUPAS') THEN 'PAGANTE DINHEIRO'
    WHEN ds_produto in ('EMV', 'EMV CREDITO', 'EMV DEBITO') THEN 'EMV'
    WHEN ds_produto in ('VT-EXP') THEN 'VALE TRANSPORTE'
    WHEN ds_produto in ('ESC.', 'PROF.')  THEN 'ESCOLAR'
    WHEN ds_produto in ('QR TESTE CPTM', 'QR TESTE VIA4', 'QR TESTE VIAMOBI') THEN 'TESTE'
    WHEN ds_produto = 'VC D TRILHO' THEN 'COMUM'
      WHEN ds_produto = 'VC M ONIBUS L' THEN 'COMUM'
      WHEN ds_produto = 'COMUM DINHEIRO' THEN 'COMUM'
      WHEN ds_produto = 'VC M INTEG. L' THEN 'COMUM'
      WHEN ds_produto = 'FIDELIDADE 10' THEN 'COMUM'
      WHEN ds_produto = 'VC D ONIBUS' THEN 'COMUM'
      WHEN ds_produto = 'VC M TRILHO L' THEN 'COMUM'
      WHEN ds_produto = 'VC M INTEG.' THEN 'COMUM'
      WHEN ds_produto = 'VC D INTEG. L' THEN 'COMUM'
      WHEN ds_produto = 'FIDELIDADE 8' THEN 'COMUM'
      WHEN ds_produto = 'VC M ONIBUS' THEN 'COMUM'
      WHEN ds_produto = 'VD D G T L' THEN 'COMUM'
      WHEN ds_produto = 'VD D G O L' THEN 'COMUM'
      WHEN ds_produto = 'ABT' THEN 'ABT'
      WHEN ds_produto = 'BENFACIL' THEN 'QR CODE'
      WHEN ds_produto = 'EMPRESARIAL' THEN 'EMPRESARIAL'
      WHEN ds_produto = 'QR METRA TRANSF' THEN 'QR CODE'
      WHEN ds_produto = 'TOP TROCA' THEN 'TOP TROCA'
      WHEN ds_produto = 'QRCODE' THEN 'QR CODE'
      WHEN ds_produto = 'EDMONSON' THEN 'PAGANTE DINHEIRO'
      WHEN ds_produto = 'TOP PROF. RGS' THEN 'ESCOLAR'
    else ds_produto
    end ds_mascara_produto
    ,CASE
    WHEN nm_linha = '0-LINHA DEFAULT'THEN '0-LINHA DEFAULT'
    WHEN nm_linha = 'LINHA 0'THEN '0-LINHA DEFAULT'
    WHEN nm_linha = 'BLOQUEIO NÃO CADASTRADO'THEN 'BLOQUEIO NÃO CADASTRADO'
    WHEN nm_linha = 'AZUL'THEN 'LINHA 1 - AZUL'
    WHEN nm_linha = 'LINHA 1 - AZUL'THEN 'LINHA 1 - AZUL'
    WHEN nm_linha = 'LINHA 10 - TURQUESA'THEN 'LINHA 10 - TURQUESA'
    WHEN nm_linha = 'TURQUESA'THEN 'LINHA 10 - TURQUESA'
    WHEN nm_linha = 'CORAL'THEN 'LINHA 11 - CORAL'
    WHEN nm_linha = 'LINHA 11 - CORAL'THEN 'LINHA 11 - CORAL'
    WHEN nm_linha = 'LINHA 12 - SAFIRA'THEN 'LINHA 12 - SAFIRA'
    WHEN nm_linha = 'SAFIRA'THEN 'LINHA 12 - SAFIRA'
    WHEN nm_linha = 'JADE'THEN 'LINHA 13 - JADE'
    WHEN nm_linha = 'LINHA 13 - JADE'THEN 'LINHA 13 - JADE'
    WHEN nm_linha = 'LINHA 13 JADE'THEN 'LINHA 13 - JADE'
    WHEN nm_linha = 'LINHA 15 - PRATA'THEN 'LINHA 15 - PRATA'
    WHEN nm_linha = 'PRATA'THEN 'LINHA 15 - PRATA'
    WHEN nm_linha = 'LINHA 2 - VERDE'THEN 'LINHA 2 - VERDE'
    WHEN nm_linha = 'VERDE'THEN 'LINHA 2 - VERDE'
    WHEN nm_linha = 'LINHA 3 - VERMELHA'THEN 'LINHA 3 - VERMELHA'
    WHEN nm_linha = 'VERMELHA'THEN 'LINHA 3 - VERMELHA'
    WHEN nm_linha = 'AMARELA'THEN 'LINHA 4 - AMARELA'
    WHEN nm_linha = 'LINHA 4 - AMARELA'THEN 'LINHA 4 - AMARELA'
    WHEN nm_linha = 'LILAS'THEN 'LINHA 5 - LILAS'
    WHEN nm_linha = 'LINHA 5 - LILAS'THEN 'LINHA 5 - LILAS'
    WHEN nm_linha = 'LINHA 7 - RUBI'THEN 'LINHA 7 - RUBI'
    WHEN nm_linha = 'RUBI'THEN 'LINHA 7 - RUBI'
    WHEN nm_linha = 'DIAMANTE'THEN 'LINHA 8 - DIAMANTE'
    WHEN nm_linha = 'LINHA 8 - DIAMANTE'THEN 'LINHA 8 - DIAMANTE'
    WHEN nm_linha = 'ESMERALDA'THEN 'LINHA 9 - ESMERALDA'
    WHEN nm_linha = 'LINHA 9 - ESMERALDA'THEN 'LINHA 9 - ESMERALDA'
    WHEN nm_linha = 'LINHA LAB AUTOPASS-METRO'THEN 'LINHA LAB AUTOPASS-METRO'
    WHEN nm_linha = 'EMBU-GUACU (CHACARA FLORIDA) - ITAPECERICA DA SERRA (VALO VELHO)'THEN 'N/A'
    ELSE nm_linha
    END nm_mascara_linha --adicionado em 4/7
    ,CASE
    WHEN nm_estacao = '0-LINHA DEFAULT' THEN '0-LINHA DEFAULT'
    WHEN nm_estacao = 'AACD' THEN 'AACD-SERVIDOR'
    WHEN nm_estacao = 'AACD-SERVIDOR' THEN 'AACD-SERVIDOR'
    WHEN nm_estacao = 'ADOLFO PINHEIRO' THEN 'ADOLFO PINHEIRO'
    WHEN nm_estacao = 'AEROPORTO - GUARULHOS' THEN 'AEROPORTO - GUARULHOS'
    WHEN nm_estacao = 'AEROPORTO GUARULHOS' THEN 'AEROPORTO - GUARULHOS'
    WHEN nm_estacao = 'AGUA BRANCA' THEN 'AGUA BRANCA'
    WHEN nm_estacao = 'ALTO BOA VISTA' THEN 'ALTO DA BOA VISTA'
    WHEN nm_estacao = 'ALTO DA BOA VISTA' THEN 'ALTO DA BOA VISTA'
    WHEN nm_estacao = 'ALTO DO IPIRANGA' THEN 'ALTO DO IPIRANGA'
    WHEN nm_estacao = 'ANA ROSA' THEN 'ANA ROSA'
    WHEN nm_estacao = 'ANHANGABAU' THEN 'ANHANGABAU'
    WHEN nm_estacao = 'ANTONIO GIANETTI' THEN 'ANTONIO GIANETTI'
    WHEN nm_estacao = 'ANTONIO JOAO' THEN 'ANTONIO JOAO'
    WHEN nm_estacao = 'ARACARE' THEN 'ARACARE'
    WHEN nm_estacao = 'ARMENIA' THEN 'ARMENIA'
    WHEN nm_estacao = 'ARTHUR ALVIN' THEN 'ARTUR ALVIM'
    WHEN nm_estacao = 'ARTUR ALVIM' THEN 'ARTUR ALVIM'
    WHEN nm_estacao = 'AUTODROMO' THEN 'AUTODROMO'
    WHEN nm_estacao = 'BALTAZAR FIDELIS' THEN 'BALTAZAR FIDELIS'
    WHEN nm_estacao = 'BARRA FUNDA' THEN 'BARRA FUNDA'
    WHEN nm_estacao = 'BARUERI' THEN 'BARUERI'
    WHEN nm_estacao = 'BELEM' THEN 'BELEM'
    WHEN nm_estacao = 'BERRINI' THEN 'BERRINI'
    WHEN nm_estacao = 'BLOQUEIO NÃO CADASTRADO' THEN 'BLOQUEIO NÃO CADASTRADO'
    WHEN nm_estacao = 'BORBA GATO' THEN 'BORBA GATO'
    WHEN nm_estacao = 'BOTUJURU' THEN 'BOTUJURU'
    WHEN nm_estacao = 'BRAS' THEN 'BRAS'
    WHEN nm_estacao = 'BRAS CUBAS' THEN 'BRAS CUBAS'
    WHEN nm_estacao = 'BRESSER' THEN 'BRESSER - MOOCA'
    WHEN nm_estacao = 'BRESSER  MOOCA' THEN 'BRESSER - MOOCA'
    WHEN nm_estacao = 'BRESSER - MOOCA' THEN 'BRESSER - MOOCA'
    WHEN nm_estacao = 'BRIGADEIRO' THEN 'BRIGADEIRO'
    WHEN nm_estacao = 'BROOKLIN' THEN 'BROOKLIN'
    WHEN nm_estacao = 'BUTANTA' THEN 'BUTANTA'
    WHEN nm_estacao = 'CAIEIRAS' THEN 'CAIEIRAS'
    WHEN nm_estacao = 'CALMOM VIANA' THEN 'CALMON VIANA'
    WHEN nm_estacao = 'CALMON VIANA' THEN 'CALMON VIANA'
    WHEN nm_estacao = 'CAMILO HADDAD' THEN 'CAMILO HADDAD'
    WHEN nm_estacao = 'CAMPO BELO' THEN 'CAMPO BELO'
    WHEN nm_estacao = 'CAMPO LIMPO' THEN 'CAMPO LIMPO'
    WHEN nm_estacao = 'CAMPO LIMPO PAULISTA' THEN 'CAMPO LIMPO PAULISTA'
    WHEN nm_estacao = 'CAPAO REDONDO' THEN 'CAPAO REDONDO'
    WHEN nm_estacao = 'CAPUAVA' THEN 'CAPUAVA'
    WHEN nm_estacao = 'CARANDIRU' THEN 'CARANDIRU'
    WHEN nm_estacao = 'CARAPICUIBA' THEN 'CARAPICUIBA'
    WHEN nm_estacao = 'CARRAO' THEN 'CARRAO'
    WHEN nm_estacao = 'CEASA' THEN 'CEASA'
    WHEN nm_estacao = 'CHACARA KLABIN' THEN 'CHACARA KLABIN'
    WHEN nm_estacao = 'CIDADE JARDIM' THEN 'CIDADE JARDIM'
    WHEN nm_estacao = 'CIDADE UNIVERSITARIA' THEN 'CIDADE UNIVERSITARIA'
    WHEN nm_estacao = 'CLINICAS' THEN 'CLINICAS'
    WHEN nm_estacao = 'COM. ERMELINO' THEN 'COMENDADOR ERMELINO'
    WHEN nm_estacao = 'COMANDANTE SAMPAIO' THEN 'COMANDANTE SAMPAIO'
    WHEN nm_estacao = 'COMENDADOR ERMELINO' THEN 'COMENDADOR ERMELINO'
    WHEN nm_estacao = 'CONCEICAO' THEN 'CONCEICAO'
    WHEN nm_estacao = 'CONSOLACAO' THEN 'CONSOLACAO'
    WHEN nm_estacao = 'CORINTHIANS - ITAQUERA' THEN 'CORINTHIANS - ITAQUERA'
    WHEN nm_estacao = 'CORINTHIANS ITAQUERA' THEN 'CORINTHIANS - ITAQUERA'
    WHEN nm_estacao = 'CPBAR' THEN 'N/A'
    WHEN nm_estacao = 'DOM BOSCO' THEN 'DOM BOSCO'
    WHEN nm_estacao = 'DOMINGOS DE MORAIS' THEN 'DOMINGOS DE MORAES'
    WHEN nm_estacao = 'EMBU-GUACU (CHACARA FLORIDA) - ITAPECERICA DA SERRA (VALO VELHO)' THEN 'N/A'
    WHEN nm_estacao = 'ENG. CARDOSO' THEN 'ENGENHEIRO CARDOSO'
    WHEN nm_estacao = 'ENGENHEIRO CARDOSO' THEN 'ENGENHEIRO CARDOSO'
    WHEN nm_estacao = 'ENGENHEIRO GOULART' THEN 'ENGENHEIRO GOULART'
    WHEN nm_estacao = 'ESTUDANTES' THEN 'ESTUDANTES'
    WHEN nm_estacao = 'EUCALIPTOS' THEN 'EUCALIPTOS'
    WHEN nm_estacao = 'FARIA LIMA' THEN 'FARIA LIMA'
    WHEN nm_estacao = 'FAZENDA DA JUTA' THEN 'FAZENDA DA JUTA'
    WHEN nm_estacao = 'FAZENDA JUTA' THEN 'FAZENDA DA JUTA'
    WHEN nm_estacao = 'FERRAZ' THEN 'FERRAZ DE VASCONCELOS'
    WHEN nm_estacao = 'FERRAZ DE VASCONCELOS' THEN 'FERRAZ DE VASCONCELOS'
    WHEN nm_estacao = 'FRAD COUTINHO' THEN 'FRADIQUE COUTINHO'
    WHEN nm_estacao = 'FRADIQUE COUTINHO' THEN 'FRADIQUE COUTINHO'
