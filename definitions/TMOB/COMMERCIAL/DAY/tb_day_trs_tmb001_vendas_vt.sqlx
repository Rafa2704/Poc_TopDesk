),

SILVER AS (
SELECT
    CAST(SUBSTR(data_credito, 1, 10) AS DATE) AS dt_credit,
    TIMESTAMP_SUB(CAST(data_processamento AS TIMESTAMP), INTERVAL 3 HOUR) AS dt_process,
    CAST(releaseDate AS DATE) AS dt_release,
    CAST(paymentDate AS DATE) AS dt_payment,
    canal as ds_channel,
    tipo_pagamento as ds_payment_mode,
    company as ds_provider,
    cod_empresa_sbe as cd_provider,
    salOrderId as cd_sales_order,
    aplicacao as ds_aplication,



    CAST(totalValue AS numeric) / 100.0 AS vl_amount,
    CAST(value AS numeric) / 100.0 AS vl_recharge,
    CAST(so_credentialtax AS numeric) / 100.0 AS vl_credential_tax,

    tipo_pedido as ds_order_type,
    status as cd_status,
    resultado_processamento as ds_process_result,
    document as nr_registered_number,
    CAST(date AS DATE)  as dt_sales_order ,
    blameUser,
    commerceordernumber  as cd_recharge_order,
    ds_provider_type,

     -- Campos de controle
  "TMB001" AS origem,
  CURRENT_TIMESTAMP() AS dt_processamento,
  SESSION_USER() AS usuario_processamento


FROM `dev-autopass-bi-001.ext.ext_vendas_vt_teste1`
 --${ref("tb_ext_trs_tmb001_vendas_vt")}
--`day.tb_his_trs_top001_vendas_vt`
),


FINAL AS (

    SELECT
    dt_credit ,
    dt_process,
    dt_release,
    dt_payment,
    ds_channel,
    ds_payment_mode,
    ds_provider,
    cd_provider,
    cd_sales_order,
    ds_aplication,
    vl_amount  ,
    vl_recharge,
    vl_credential_tax,
       CASE 
        WHEN cd_recharge_order IN(SELECT pedido FROM pedidos_ted) 
            THEN vl_recharge 
            ELSE vl_amount
    END Vl_received_escrow,
    ds_order_type,
    cd_status,
    ds_process_result,
    nr_registered_number,
    dt_sales_order,
    blameUser,
    cd_recharge_order,
    ds_provider_type,
    origem,
    dt_processamento,
    usuario_processamento

 
FROM SILVER s 
LEFT JOIN pedidos_ted p ON s.cd_recharge_order = p.pedido

)

SELECT * FROM FINAL
