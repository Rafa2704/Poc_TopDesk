config {
    type: "incremental", // Criamos como tabela para ter os dados fisicamente no BQ
    schema: "his",
    name: "tb_his_mrd_tpd001_operators",
    uniqueKey: ["id"],
    description: "Camada Bronze: Dados persistidos como texto para garantir resiliência contra mudanças de schema",
    tags: ["topdesk"],
}


SELECT 
        branchId,
        budgetHolderId,
        creationDate,
        departmentId,
        email,
        employeeNumber,
        id,
        loginName,
        mobileNumber,
        modificationDate,
        name,
        status,
        telephoneNumber
FROM ${ref("tb_day_mrd_tpd001_operators")}