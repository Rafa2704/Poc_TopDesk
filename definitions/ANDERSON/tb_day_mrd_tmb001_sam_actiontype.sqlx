config {
  type: "table",
  schema: "day",
  name: "tb_day_mrd_tmb001_sam_actiontype",
  description: "Tabela dimensao",
  tags: ["commercial"],
}


SELECT 
  sat_code,
  sat_description,
-- Campos de controle
  "TMB001" AS origem,
  CURRENT_TIMESTAMP() AS dt_processamento,
  SESSION_USER() AS usuario_processamento

FROM ${ref("tb_ext_mrd_tmb001_sam_actiontype")}